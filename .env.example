# ==============================================================================
# E-Certificate Platform Configuration Environment Variables
# Copy this file to '.env' and modify settings for your deployment.
# ==============================================================================

# Timezone
TZ=Asia/Bangkok

# Database Configuration
POSTGRES_DB=ecert
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
# Database URL for containers (use db hostname 'postgres')
DATABASE_URL=postgresql://app:secret@postgres:5432/ecert

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# MinIO Object Storage Configuration
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret
BUCKET_NAME=certificates

# Storage Endpoints
# Internal endpoint used by API & Worker containers to talk to MinIO
STORAGE_ENDPOINT=http://minio:9000
# External domain where the application is hosted (IP or domain name)
DOMAIN=localhost
# Publicly accessible endpoint to download certificates from MinIO
EXTERNAL_STORAGE_ENDPOINT=http://localhost/certificates

# Security Configuration
# Secret key used for JWT token signing. Choose a strong random key in production!
SECRET_KEY=supersecretkeyforecertificatesystem12345!

# Network Ports
API_PORT=8000
WEB_PORT=80
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
POSTGRES_PORT=5432
REDIS_PORT=6379
